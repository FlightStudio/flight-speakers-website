{
  "name": "flight-speakers-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node --watch --env-file=.env server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:seed": "node --env-file=.env server/db/seed.js",
    "db:embed": "node --env-file=.env server/db/seed-embeddings.js",
    "db:seed-enquiries": "node --env-file=.env server/db/seed-enquiries.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@google-cloud/storage": "^7.19.0",
    "@react-pdf/renderer": "^4.3.2",
    "@react-spring/web": "^10.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.29.0",
    "gsap": "^3.14.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lenis": "^1.3.17",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "pg": "^8.18.0",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0",
    "resend": "^6.14.0",
    "three": "^0.182.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  }
}
